{
	"tab_size": 2,
	"hard_tabs": true,
	"format_on_save": "on",
	"formatter": {
		"external": {
			"command": "pnpm",
			"arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
		}
	},
	"languages": {
		"Svelte": {
			"tab_size": 2,
			"hard_tabs": true
		},
		"TypeScript": {
			"tab_size": 2,
			"hard_tabs": true
		},
		"JSON": {
			"tab_size": 2,
			"hard_tabs": true
		}
	},
	"lsp": {
		"svelte-language-server": {
			"settings": {
				"svelte": {
					"plugin": {
						"svelte": {
							"compilerWarnings": {
								"a11y-no-onchange": "warning"
							}
						}
					}
				}
			}
		}
	}
}
