{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(pnpm install)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pnpm run build)",
      "Bash(pnpm run check)",
      "Bash(pnpm run check:watch)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run format)",
      "Bash(pnpm exec svelte-check)",
      "Bash(pnpm exec prettier *)",
      "Bash(pnpm exec eslint *)",
      "Bash(git status)",
      "Bash(git status -uno)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git remote -v)"
    ],
    "deny": [
      "Bash(pnpm dev*)",
      "Bash(pnpm run dev*)",
      "Bash(npm run dev*)",
      "Bash(npm dev*)",
      "Bash(vite dev*)",
      "Bash(vite*)",
      "Bash(pnpm preview*)",
      "Bash(pnpm run preview*)",
      "Bash(npm run preview*)",
      "Bash(git rebase -i*)",
      "Bash(git add -i*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Read(.env)",
      "Read(.env.*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-on-edit.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash\\(git push.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-check.sh",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  }
}
