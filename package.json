    "eslint": "10.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "^15.0.0",
    "lefthook": "2.1.5",
    "prettier": "3.8.2",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.3",
    "svelte-check": "4.4.6",
    "svelte-eslint-parser": "^1.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8"
